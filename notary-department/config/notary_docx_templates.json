{
  "_meta": {
    "description": "תבניות DOCX נוטריוניות — Agent 2 קורא מכאן בכל הפקת מסמך",
    "last_updated": "2026-03-28",
    "used_by": ["agents/agent2_expert_notary.md", "scripts/generate_notary_docx.py"]
  },

  "global_styles": {
    "page": {
      "size": "A4",
      "width_cm": 21,
      "height_cm": 29.7,
      "margins_cm": 2.5
    },
    "fonts": {
      "hebrew": { "name": "David", "size_pt": 12, "direction": "RTL" },
      "english": { "name": "Times New Roman", "size_pt": 12, "direction": "LTR" },
      "russian": { "name": "Times New Roman", "size_pt": 12, "direction": "LTR" },
      "arabic": { "name": "Traditional Arabic", "size_pt": 14, "direction": "RTL" }
    },
    "line_spacing": 1.5,
    "title": { "size_pt": 16, "bold": true, "alignment": "center" },
    "subtitle": { "size_pt": 13, "bold": true, "alignment": "center" },
    "body": { "size_pt": 12, "bold": false },
    "header": {
      "line1": "{firm_name_he}  |  {firm_name_en}",
      "line2": "{address}  |  ☎ {phone}  |  📠 {fax}  |  ✉ {email}",
      "font_size_pt": 10,
      "border_bottom": true
    },
    "footer": {
      "text_he": "מסמך חסוי — יחסי עו״ד-לקוח",
      "text_en": "Confidential — Attorney-Client Privilege",
      "page_numbers": true,
      "font_size_pt": 8,
      "border_top": true
    },
    "colors": {
      "dark_blue": "#1A3C6E",
      "black": "#000000",
      "gray": "#666666",
      "table_header_bg": "#F0F4FA",
      "total_row_bg": "#E8F0E8"
    }
  },

  "notary_defaults": {
    "name_he": "עו״ד דניאל בית-און",
    "name_en": "Adv. Daniel Beit-On",
    "license_no": "54321",
    "address_he": "רח׳ רוטשילד 42, תל אביב-יפו 6688312",
    "address_en": "42 Rothschild Blvd., Tel Aviv-Yafo 6688312",
    "phone": "03-1234567",
    "fax": "03-1234568",
    "email": "notary@firm.co.il"
  },

  "firm": {
    "name_he": "משרד עורכי דין בית-און ושות׳",
    "name_en": "Beit-On & Co. Law Offices"
  },

  "templates": {

    "translation_approval": {
      "id": "translation_approval",
      "name_he": "אישור נכונות תרגום",
      "name_en": "Certificate of Translation Accuracy",
      "legal_ref": "ס׳ 7(4) לחוק הנוטריונים, תשל״ו-1976",
      "fee_ref": "פרט 3 לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978",
      "cert_prefix": "TRANS",
      "sections": [
        {
          "id": "title",
          "type": "bilingual_title",
          "text_he": "אישור נכונות תרגום מס׳ {cert_number}",
          "text_en": "Certificate of Translation Accuracy No. {cert_number}"
        },
        {
          "id": "notary_intro",
          "type": "bilingual_text",
          "text_he": "אני, {notary_name_he}, נוטריון מס׳ {license_no}, מאשר בזאת כי:",
          "text_en": "I, {notary_name_en}, Notary Public No. {license_no}, hereby certify that:"
        },
        {
          "id": "document_description",
          "type": "table",
          "fields": [
            { "label_he": "סוג המסמך", "label_en": "Document Type", "value": "{doc_type_he}  |  {doc_type_en}" },
            { "label_he": "שפת מקור", "label_en": "Source Language", "value": "{source_lang_he}  |  {source_lang_en}" },
            { "label_he": "שפת יעד", "label_en": "Target Language", "value": "{target_lang_he}  |  {target_lang_en}" },
            { "label_he": "מספר עמודים", "label_en": "Page Count", "value": "{page_count}" },
            { "label_he": "מספר מילים", "label_en": "Word Count", "value": "{word_count}" }
          ]
        },
        {
          "id": "original_text",
          "type": "document_block",
          "title_he": "המסמך המקורי",
          "title_en": "Original Document",
          "direction": "{source_direction}",
          "font": "{source_font}",
          "end_marker_he": "סוף המקור",
          "end_marker_en": "End of Original"
        },
        {
          "id": "translation_text",
          "type": "document_block",
          "title_he": "התרגום",
          "title_en": "Translation",
          "direction": "{target_direction}",
          "font": "{target_font}",
          "end_marker_he": "סוף התרגום",
          "end_marker_en": "End of Translation"
        },
        {
          "id": "notary_declaration",
          "type": "bilingual_text",
          "text_he": "אני, הח״מ {notary_name_he}, נוטריון מס׳ {license_no}, מאשר בזאת כי התרגום דלעיל מ{source_lang_he} ל{target_lang_he} הינו תרגום נאמן ומלא של המסמך המקורי שהוצג בפניי. התרגום בוצע על ידי ושפות אלו ידועות לי.",
          "text_en": "I, the undersigned, {notary_name_en}, Notary Public No. {license_no}, hereby certify that the above is a true and faithful translation from {source_lang_en} to {target_lang_en} of the original document presented to me. The translation was made by me and I am proficient in both languages."
        },
        {
          "id": "fee_table",
          "type": "fee_breakdown",
          "source": "config/notary_pricing_2026.json",
          "pricing_key": "translation_approval",
          "regulation_note_he": "בהתאם לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978, פרט 3",
          "regulation_note_en": "In accordance with the Notaries Regulations (Service Fees), 5739-1978, Schedule 3",
          "fields": [
            { "label_he": "מספר מילים במקור", "label_en": "Source Word Count", "value": "{word_count}" },
            { "label_he": "שכר אישור תרגום", "label_en": "Translation Certification Fee", "value": "{base_fee}" },
            { "label_he": "תוספת תרגום ע״י נוטריון (50%)", "label_en": "Notary Translation Surcharge", "value": "{surcharge}" },
            { "label_he": "סה״כ לפני מע״מ", "label_en": "Subtotal Before VAT", "value": "{total_before_vat}" },
            { "label_he": "מע״מ", "label_en": "VAT ({vat_rate}%)", "value": "{vat}" },
            { "label_he": "סה״כ", "label_en": "Total", "value": "{total}", "bold": true }
          ]
        },
        {
          "id": "signature_block",
          "type": "signature",
          "fields": ["date", "signature", "seal", "notary_name_and_license"]
        }
      ]
    },

    "translator_declaration": {
      "id": "translator_declaration",
      "name_he": "אישור הצהרת מתרגם",
      "name_en": "Translator Declaration Certificate",
      "legal_ref": "תקנות הנוטריונים, תשל״ז-1977, תקנה 11א",
      "fee_ref": "פרט 1 לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978",
      "cert_prefix": "TDEC",
      "sections": [
        {
          "id": "title",
          "type": "bilingual_title",
          "text_he": "אישור הצהרת מתרגם מס׳ {cert_number}",
          "text_en": "Translator Declaration Certificate No. {cert_number}"
        },
        {
          "id": "notary_intro",
          "type": "bilingual_text",
          "text_he": "אני, {notary_name_he}, נוטריון מס׳ {license_no}, מאשר בזאת כי:",
          "text_en": "I, {notary_name_en}, Notary Public No. {license_no}, hereby certify that:"
        },
        {
          "id": "translator_details",
          "type": "table",
          "fields": [
            { "label_he": "שם המתרגם", "label_en": "Translator Name", "value": "{translator_name}" },
            { "label_he": "ת.ז. המתרגם", "label_en": "Translator ID", "value": "{translator_id}" },
            { "label_he": "סוג המסמך", "label_en": "Document Type", "value": "{doc_type_he}  |  {doc_type_en}" },
            { "label_he": "שפת מקור", "label_en": "Source Language", "value": "{source_lang_he}  |  {source_lang_en}" },
            { "label_he": "שפת יעד", "label_en": "Target Language", "value": "{target_lang_he}  |  {target_lang_en}" },
            { "label_he": "מספר מילים", "label_en": "Word Count", "value": "{word_count}" }
          ]
        },
        {
          "id": "original_text",
          "type": "document_block",
          "title_he": "המסמך המקורי",
          "title_en": "Original Document",
          "direction": "{source_direction}",
          "font": "{source_font}",
          "end_marker_he": "סוף המקור",
          "end_marker_en": "End of Original"
        },
        {
          "id": "translation_text",
          "type": "document_block",
          "title_he": "התרגום",
          "title_en": "Translation",
          "direction": "{target_direction}",
          "font": "{target_font}",
          "end_marker_he": "סוף התרגום",
          "end_marker_en": "End of Translation"
        },
        {
          "id": "notary_declaration",
          "type": "bilingual_text",
          "text_he": "אני מאשר בזאת כי מר/גב׳ {translator_name}, ת.ז. {translator_id}, הצהיר/ה בפניי כי הוא/היא שולט/ת בשפה ה{source_lang_he} ובשפה ה{target_lang_he} וכי התרגום דלעיל הוא תרגום נאמן ומלא של המסמך המקורי.",
          "text_en": "I hereby certify that Mr./Ms. {translator_name}, ID No. {translator_id}, declared before me that he/she is proficient in {source_lang_en} and {target_lang_en} and that the above translation is a true and complete translation of the original document."
        },
        {
          "id": "disclaimer",
          "type": "warning_box",
          "text_he": "הערה: אישור זה אינו מהווה אישור נכונות התרגום על ידי הנוטריון.",
          "text_en": "Note: This certificate does not constitute a certification of the accuracy of the translation by the Notary.",
          "style": "bold_red_border"
        },
        {
          "id": "fee_table",
          "type": "fee_breakdown",
          "source": "config/notary_pricing_2026.json",
          "pricing_key": "signature_authentication",
          "regulation_note_he": "בהתאם לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978, פרט 1",
          "regulation_note_en": "In accordance with the Notaries Regulations (Service Fees), 5739-1978, Schedule 1"
        },
        {
          "id": "signature_block",
          "type": "signature",
          "fields": ["date", "signature", "seal", "notary_name_and_license"]
        }
      ]
    },

    "power_of_attorney": {
      "id": "power_of_attorney",
      "name_he": "ייפוי כוח נוטריוני",
      "name_en": "Notarial Power of Attorney",
      "legal_ref": "ס׳ 20א לחוק הנוטריונים, תשל״ו-1976",
      "fee_ref": "פרט 1 לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978",
      "cert_prefix": "POA",
      "sections": [
        {
          "id": "title",
          "type": "bilingual_title",
          "text_he": "ייפוי כוח נוטריוני מס׳ {cert_number}",
          "text_en": "Notarial Power of Attorney No. {cert_number}"
        },
        {
          "id": "notary_intro",
          "type": "bilingual_text",
          "text_he": "אני, {notary_name_he}, נוטריון מס׳ {license_no}, מאשר בזאת כי:",
          "text_en": "I, {notary_name_en}, Notary Public No. {license_no}, hereby certify that:"
        },
        {
          "id": "principal_details",
          "type": "section_header",
          "title_he": "פרטי מייפה הכוח",
          "title_en": "Principal Details",
          "fields": [
            { "label_he": "שם", "label_en": "Name", "value": "{principal_name}" },
            { "label_he": "ת.ז. / דרכון", "label_en": "ID / Passport", "value": "{principal_id}" },
            { "label_he": "כתובת", "label_en": "Address", "value": "{principal_address}" }
          ]
        },
        {
          "id": "attorney_details",
          "type": "section_header",
          "title_he": "פרטי מיופה הכוח",
          "title_en": "Attorney-in-Fact Details",
          "fields": [
            { "label_he": "שם", "label_en": "Name", "value": "{attorney_name}" },
            { "label_he": "ת.ז. / דרכון", "label_en": "ID / Passport", "value": "{attorney_id}" },
            { "label_he": "כתובת", "label_en": "Address", "value": "{attorney_address}" }
          ]
        },
        {
          "id": "powers",
          "type": "document_block",
          "title_he": "ההרשאות",
          "title_en": "Powers Granted"
        },
        {
          "id": "limitations",
          "type": "document_block",
          "title_he": "הגבלות ותנאים",
          "title_en": "Limitations and Conditions"
        },
        {
          "id": "poa_type",
          "type": "checkbox_list",
          "items": [
            { "label_he": "כללי", "label_en": "General", "key": "general" },
            { "label_he": "מקרקעין", "label_en": "Real Estate", "key": "real_estate" },
            { "label_he": "בלתי חוזר", "label_en": "Irrevocable", "key": "irrevocable" },
            { "label_he": "בנקאי / משכנתא", "label_en": "Bank / Mortgage", "key": "bank_mortgage" }
          ]
        },
        {
          "id": "notary_declaration",
          "type": "bilingual_text",
          "text_he": "אני מאשר כי מייפה הכוח הנ״ל חתם בפניי על ייפוי כוח זה מרצונו החופשי, לאחר שהסברתי לו את משמעותו ותוצאותיו המשפטיות, ולאחר שזיהיתי אותו באמצעות תעודת זהות מס׳ {principal_id}.",
          "text_en": "I certify that the above-named Principal signed this Power of Attorney in my presence of his/her own free will, after I explained to him/her its meaning and legal consequences, and after I identified him/her by means of Identity Card No. {principal_id}."
        },
        {
          "id": "fee_table",
          "type": "fee_breakdown",
          "source": "config/notary_pricing_2026.json",
          "pricing_key": "signature_authentication"
        },
        {
          "id": "signature_block",
          "type": "signature",
          "fields": ["date", "principal_signature", "notary_signature", "seal", "notary_name_and_license"]
        }
      ]
    },

    "affidavit": {
      "id": "affidavit",
      "name_he": "תצהיר נוטריוני",
      "name_en": "Notarial Affidavit",
      "legal_ref": "ס׳ 7(5) לחוק הנוטריונים, תשל״ו-1976",
      "fee_ref": "פרט 5 לתקנות הנוטריונים (שכר שירותים), תשל״ט-1978",
      "cert_prefix": "AFF",
      "sections": [
        {
          "id": "title",
          "type": "bilingual_title",
          "text_he": "תצהיר נוטריוני מס׳ {cert_number}",
          "text_en": "Notarial Affidavit No. {cert_number}"
        },
        {
          "id": "declarant_details",
          "type": "table",
          "fields": [
            { "label_he": "שם המצהיר", "label_en": "Declarant Name", "value": "{declarant_name}" },
            { "label_he": "ת.ז. / דרכון", "label_en": "ID / Passport", "value": "{declarant_id}" },
            { "label_he": "כתובת", "label_en": "Address", "value": "{declarant_address}" }
          ]
        },
        {
          "id": "oath",
          "type": "bilingual_text",
          "text_he": "לאחר שהוזהרתי כי עליי להצהיר את האמת וכי אהיה צפוי לעונשים הקבועים בחוק אם לא אעשה כן, מצהיר/ה בזאת כדלקמן:",
          "text_en": "Having been warned that I must state the truth and that I shall be liable to the penalties prescribed by law if I do not do so, I hereby declare as follows:"
        },
        {
          "id": "affidavit_content",
          "type": "document_block",
          "title_he": "תוכן התצהיר",
          "title_en": "Affidavit Content",
          "numbered_paragraphs": true
        },
        {
          "id": "declarant_signature",
          "type": "signature_line",
          "text_he": "חתימת המצהיר/ה",
          "text_en": "Declarant's Signature"
        },
        {
          "id": "notary_declaration",
          "type": "bilingual_text",
          "text_he": "אני, {notary_name_he}, נוטריון מס׳ {license_no}, מאשר כי ביום {date}, הופיע/ה בפניי {declarant_name}, שזיהיתי אותו/ה באמצעות ת.ז. מס׳ {declarant_id}, ולאחר שהזהרתי אותו/ה כי עליו/ה להצהיר אמת וכי יהיה/תהיה צפוי/ה לעונשים הקבועים בחוק אם לא יעשה/תעשה כן, אישר/ה את נכונות ההצהרה דלעיל וחתם/ה עליה בפניי.",
          "text_en": "I, {notary_name_en}, Notary Public No. {license_no}, certify that on {date}, {declarant_name} appeared before me, was identified by means of ID No. {declarant_id}, and after being warned that he/she must state the truth and is liable to penalties prescribed by law if he/she fails to do so, confirmed the above declaration and signed it in my presence."
        },
        {
          "id": "fee_table",
          "type": "fee_breakdown",
          "source": "config/notary_pricing_2026.json",
          "pricing_key": "affidavit"
        },
        {
          "id": "signature_block",
          "type": "signature",
          "fields": ["date", "signature", "seal", "notary_name_and_license"]
        }
      ]
    }
  },

  "file_naming": {
    "pattern": "{cert_prefix}_{cert_number}_{doc_type}_{source_lang}-{target_lang}_{date}.docx",
    "example": "TRANS_0001_2026_divorce_certificate_he-en_2026-03-28.docx"
  },

  "output_directory": "templates/translation_docx/"
}